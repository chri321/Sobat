<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- ==================== 主内容区域 ==================== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:orientation="vertical">

        <!-- ==================== 顶部栏（汉堡菜单） ==================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/btn_hamburger"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="☰"
                android:textColor="#FF6A00"
                android:textSize="24sp"
                android:textStyle="bold" />

   
        </LinearLayout>

        <!-- ==================== 内容区域 ==================== -->
        <FrameLayout
            android:id="@+id/content_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- 主页（默认空白，通过 visibility 控制） -->
            <LinearLayout
                android:id="@+id/page_home"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- 地图页 -->
            <LinearLayout
                android:id="@+id/page_map"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:visibility="visible">

                <!-- 地图 -->
                <com.amap.api.maps.MapView
                    android:id="@+id/map"
                    android:layout_width="match_parent"
                    android:layout_height="240dp" />

                <!-- 搜索栏 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="-12dp"
                    android:background="@drawable/card_white_round"
                    android:elevation="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="14dp"
                    android:paddingEnd="6dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:alpha="0.4"
                            android:src="@android:drawable/ic_menu_search" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:layout_weight="1"
                            android:text="搜附近站点"
                            android:textColor="#999999"
                            android:textSize="14sp" />

                        <View
                            android:layout_width="1dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="6dp"
                            android:background="#EEEEEE" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:paddingStart="6dp"
                            android:paddingEnd="6dp"
                            android:text="搜索"
                            android:textColor="#FF6A00"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                </LinearLayout>

                <!-- 下方列表区 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 分类快捷入口 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/card_white_round"
                        android:elevation="2dp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <!-- 全部 -->
                        <LinearLayout
                            android:id="@+id/cat_all"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/cat_all_icon"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_orange"
                                android:gravity="center"
                                android:text="🗂️"
                                android:textSize="22sp" />
                            <TextView
                                android:id="@+id/cat_all_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="全部"
                                android:textColor="#FF6A00"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- 维修站 -->
                        <LinearLayout
                            android:id="@+id/cat_repair"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/cat_repair_icon"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_orange"
                                android:gravity="center"
                                android:text="🔧"
                                android:textSize="22sp" />
                            <TextView
                                android:id="@+id/cat_repair_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="维修站"
                                android:textColor="#333333"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- 医院 -->
                        <LinearLayout
                            android:id="@+id/cat_hospital"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/cat_hospital_icon"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_red"
                                android:gravity="center"
                                android:text="🏥"
                                android:textSize="22sp" />
                            <TextView
                                android:id="@+id/cat_hospital_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="医院"
                                android:textColor="#333333"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <!-- 充电站 -->
                        <LinearLayout
                            android:id="@+id/cat_charge"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/cat_charge_icon"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:background="@drawable/bg_icon_orange"
                                android:gravity="center"
                                android:text="🔌"
                                android:textSize="22sp" />
                            <TextView
                                android:id="@+id/cat_charge_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="6dp"
                                android:text="充电站"
                                android:textColor="#333333"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 预警横幅 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/card_yellow"
                        android:elevation="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:gravity="center"
                            android:text="⚠️"
                            android:textSize="18sp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="周边预警"
                                android:textColor="#E65100"
                                android:textSize="13sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="台风烟花预计明晚登陆，请注意出行安全"
                                android:textColor="#BF360C"
                                android:textSize="11sp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_tag_yellow"
                            android:paddingStart="8dp"
                            android:paddingTop="3dp"
                            android:paddingEnd="8dp"
                            android:paddingBottom="3dp"
                            android:text="黄色预警"
                            android:textColor="#FFFFFF"
                            android:textSize="10sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- 附近推荐标题 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="附近"
                            android:textColor="#1A1A1A"
                            android:textSize="16sp"
                            android:textStyle="bold" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="查看全部 ›"
                            android:textColor="#FF6A00"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <!-- 卡片列表 -->
                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:clipToPadding="false"
                        android:paddingStart="16dp"
                        android:paddingTop="10dp"
                        android:paddingEnd="16dp"
                        android:paddingBottom="16dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- 维修站 1 -->
                            <LinearLayout
                                android:id="@+id/card_repair_1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/card_white_round"
                                android:elevation="2dp"
                                android:orientation="horizontal"
                                android:padding="12dp">
                                <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/card_img_placeholder" android:gravity="center" android:text="🔧" android:textSize="32sp" />
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="途虎养车工场店（建设路店）" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 4.7" android:textColor="#FF6A00" android:textSize="12sp" android:textStyle="bold" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_tag_orange" android:paddingStart="6dp" android:paddingTop="1dp" android:paddingEnd="6dp" android:paddingBottom="1dp" android:text="连锁" android:textColor="#FFFFFF" android:textSize="10sp" />
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="📍 成华区建设路55号 · 1.2km" android:textColor="#999999" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🕐 营业中 08:00-20:00 · 可预约" android:textColor="#E65100" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- 医院 1 -->
                            <LinearLayout
                                android:id="@+id/card_hospital_1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/card_white_round"
                                android:elevation="2dp"
                                android:orientation="horizontal"
                                android:padding="12dp">
                                <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/card_img_placeholder" android:gravity="center" android:text="🏥" android:textSize="32sp" />
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="华西医院（本部）" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_red" android:paddingStart="6dp" android:paddingTop="1dp" android:paddingEnd="6dp" android:paddingBottom="1dp" android:text="三甲" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" />
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🟠 当前繁忙度：中等 · 排队≈32min" android:textColor="#D0021B" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="📍 武侯区国学巷37号 · 3.1km" android:textColor="#999999" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🩺 呼吸内科、心内科、骨科有号" android:textColor="#D0021B" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- 充电站 1 -->
                            <LinearLayout
                                android:id="@+id/card_charge_1"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/card_white_round"
                                android:elevation="2dp"
                                android:orientation="horizontal"
                                android:padding="12dp">
                                <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/card_img_placeholder" android:gravity="center" android:text="🔌" android:textSize="32sp" />
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="特来电充电站（天府广场）" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ 快充 120kW" android:textColor="#FF6A00" android:textSize="12sp" android:textStyle="bold" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_tag_orange" android:paddingStart="6dp" android:paddingTop="1dp" android:paddingEnd="6dp" android:paddingBottom="1dp" android:text="24h" android:textColor="#FFFFFF" android:textSize="10sp" />
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="📍 锦江区天府广场B2层 · 0.8km" android:textColor="#999999" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🟢 空闲 8/12 枪 · ¥1.2/度" android:textColor="#E65100" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- 维修站 2 -->
                            <LinearLayout
                                android:id="@+id/card_repair_2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/card_white_round"
                                android:elevation="2dp"
                                android:orientation="horizontal"
                                android:padding="12dp">
                                <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/card_img_placeholder" android:gravity="center" android:text="🔧" android:textSize="32sp" />
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="天猫养车（高新旗舰店）" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⭐ 4.9" android:textColor="#FF6A00" android:textSize="12sp" android:textStyle="bold" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_tag_orange" android:paddingStart="6dp" android:paddingTop="1dp" android:paddingEnd="6dp" android:paddingBottom="1dp" android:text="旗舰" android:textColor="#FFFFFF" android:textSize="10sp" />
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="📍 高新区天府大道999号 · 4.5km" android:textColor="#999999" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🕐 营业中 09:00-21:00 · 免费检测" android:textColor="#E65100" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- 医院 2 -->
                            <LinearLayout
                                android:id="@+id/card_hospital_2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/card_white_round"
                                android:elevation="2dp"
                                android:orientation="horizontal"
                                android:padding="12dp">
                                <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/card_img_placeholder" android:gravity="center" android:text="🏥" android:textSize="32sp" />
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical">
                                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="成都市第一人民医院" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_tag_red" android:paddingStart="6dp" android:paddingTop="1dp" android:paddingEnd="6dp" android:paddingBottom="1dp" android:text="三甲" android:textColor="#FFFFFF" android:textSize="10sp" android:textStyle="bold" />
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🟠 当前繁忙度：较高 · 排队≈45min" android:textColor="#D0021B" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="📍 高新区万象北路18号 · 5.6km" android:textColor="#999999" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🚑 急诊 24 小时 · 发热门诊开放" android:textColor="#D0021B" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- 充电站 2 -->
                            <LinearLayout
                                android:id="@+id/card_charge_2"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/card_white_round"
                                android:elevation="2dp"
                                android:orientation="horizontal"
                                android:padding="12dp">
                                <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/card_img_placeholder" android:gravity="center" android:text="🔌" android:textSize="32sp" />
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="星星充电站（万象城）" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ 快充 60kW" android:textColor="#FF6A00" android:textSize="12sp" android:textStyle="bold" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_tag_orange" android:paddingStart="6dp" android:paddingTop="1dp" android:paddingEnd="6dp" android:paddingBottom="1dp" android:text="优惠" android:textColor="#FFFFFF" android:textSize="10sp" />
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="📍 成华区双庆路8号B1 · 2.9km" android:textColor="#999999" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🟡 空闲 3/6 枪 · ¥0.98/度（谷时）" android:textColor="#E65100" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <!-- 充电站 3 -->
                            <LinearLayout
                                android:id="@+id/card_charge_3"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/card_white_round"
                                android:elevation="2dp"
                                android:orientation="horizontal"
                                android:padding="12dp">
                                <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/card_img_placeholder" android:gravity="center" android:text="🔌" android:textSize="32sp" />
                                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="小桔充电（环球中心）" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold" />
                                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:gravity="center_vertical">
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="⚡ 超充 480kW" android:textColor="#FF6A00" android:textSize="12sp" android:textStyle="bold" />
                                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:background="@drawable/bg_tag_orange" android:paddingStart="6dp" android:paddingTop="1dp" android:paddingEnd="6dp" android:paddingBottom="1dp" android:text="新站" android:textColor="#FFFFFF" android:textSize="10sp" />
                                    </LinearLayout>
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="📍 高新区天府大道1700号 · 6.2km" android:textColor="#999999" android:textSize="11sp" />
                                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="🟢 空闲 16/20 枪 · ¥1.5/度" android:textColor="#E65100" android:textSize="11sp" />
                                </LinearLayout>
                            </LinearLayout>

                        </LinearLayout>
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>

            <!-- 社群页（占位） -->
            <LinearLayout
                android:id="@+id/page_community"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="社群"
                    android:textColor="#CCCCCC"
                    android:textSize="18sp" />
            </LinearLayout>

            <!-- 个人页（占位） -->
            <LinearLayout
                android:id="@+id/page_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:visibility="gone">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="个人"
                    android:textColor="#CCCCCC"
                    android:textSize="18sp" />
            </LinearLayout>
        </FrameLayout>

        <!-- ==================== 底部导航栏 ==================== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="#FFFFFF"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <!-- 主页 -->
                <LinearLayout
                    android:id="@+id/nav_home"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/nav_home_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_home"
                        android:contentDescription="主页" />
                    <TextView
                        android:id="@+id/nav_home_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="主页"
                        android:textColor="#999999"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- 地图 -->
                <LinearLayout
                    android:id="@+id/nav_map"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/nav_map_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_map"
                        android:contentDescription="地图" />
                    <TextView
                        android:id="@+id/nav_map_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="地图"
                        android:textColor="#FF6A00"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- 问AI（加大、居中凸出） -->
                <LinearLayout
                    android:id="@+id/nav_ai"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.4"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/nav_ai_icon"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginTop="0dp"
                        android:background="@drawable/bg_ai_button"
                        android:elevation="4dp"
                        android:src="@drawable/ic_nav_ai"
                        android:padding="12dp"
                        android:contentDescription="问AI" />
                    <TextView
                        android:id="@+id/nav_ai_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:text="AI"
                        android:textColor="#999999"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- 社群 -->
                <LinearLayout
                    android:id="@+id/nav_community"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/nav_community_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_community"
                        android:contentDescription="社群" />
                    <TextView
                        android:id="@+id/nav_community_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="社群"
                        android:textColor="#999999"
                        android:textSize="10sp" />
                </LinearLayout>

                <!-- 个人 -->
                <LinearLayout
                    android:id="@+id/nav_profile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/nav_profile_icon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_nav_profile"
                        android:contentDescription="个人" />
                    <TextView
                        android:id="@+id/nav_profile_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="个人"
                        android:textColor="#999999"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

    </LinearLayout>

    <!-- ==================== 侧滑抽屉菜单 ==================== -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/drawer_header"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
